# Copy this to .env.local and fill in values

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better-auth (Phase 0 Step 6)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# OAuth (Phase 1+, optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 (Phase 0 Step 9)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=valbook-dev
R2_PUBLIC_URL=

# Resend (Phase 0 Step 10)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@valbook.com

# Upstash Redis (Phase 0 Step 11)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Exchange rates (Phase 0 Step 16)
FRANKFURTER_URL=https://api.frankfurter.app
COINGECKO_API_KEY=

# Cron (Phase 0 Step 16)
CRON_SECRET=

# Sentry (Phase 0 Step 12)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
